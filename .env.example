# Neon (serverless Postgres) connection string — project `clickshop`
DATABASE_URL=postgres://user:password@ep-example.neon.tech/clickshop?sslmode=require

# LLM Engine — Gemini via its OpenAI-compatible endpoint (ADR-0006).
# Get a key at console.cloud.google.com / ai.google.dev.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Fixed seed for deterministic demo data (Q20 / PRD Section 4 "Seed history")
SEED_RNG_SEED=clickshop-demo-v1
